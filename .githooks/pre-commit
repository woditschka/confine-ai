#!/usr/bin/env bash
# Pre-commit hook: block secrets, credentials, and local settings,
# then format and vet Go code before committing.
# Install: make hooks

set -e

# --- Secret and credential checks ---

STAGED=$(git diff --cached --name-only --diff-filter=ACM)
if [ -z "$STAGED" ]; then
    exit 0
fi

BLOCKED=""

# Forbidden file patterns
while IFS= read -r f; do
    case "$f" in
        .claude/settings.local.json)
            ;; # project-local Claude Code permissions — not sensitive
        .env|.env.*)
            BLOCKED="$BLOCKED\n  $f  (environment file)" ;;
        *.env)
            BLOCKED="$BLOCKED\n  $f  (environment file)" ;;
        *.pem|*.key|*.p12|*.pfx|*.jks)
            BLOCKED="$BLOCKED\n  $f  (private key / keystore)" ;;
        *credentials*|*secret*)
            BLOCKED="$BLOCKED\n  $f  (credentials / secret file)" ;;
        *.local.json|*.local.yaml|*.local.toml)
            BLOCKED="$BLOCKED\n  $f  (machine-local settings)" ;;
        *id_rsa|*id_ed25519|*id_ecdsa)
            BLOCKED="$BLOCKED\n  $f  (SSH private key)" ;;
        *.keystore|*.truststore)
            BLOCKED="$BLOCKED\n  $f  (Java key/trust store)" ;;
        .npmrc|.pypirc)
            BLOCKED="$BLOCKED\n  $f  (package registry auth)" ;;
        .netrc|.docker/config.json)
            BLOCKED="$BLOCKED\n  $f  (auth config)" ;;
    esac
done <<< "$STAGED"

# Forbidden content in staged diffs (additions only)
DIFF=$(git diff --cached -U0)
CONTENT_HITS=$(printf '%s\n' "$DIFF" | grep -nE '^\+' | grep -vE '^\+\+\+' | grep -iE \
    'BEGIN.*PRIVATE KEY|sk-[a-zA-Z0-9-]{20,}|ghp_[a-zA-Z0-9]{36}|ghs_[a-zA-Z0-9]{36}|glpat-[a-zA-Z0-9-]{20,}|AKIA[0-9A-Z]{16}|xox[bpors]-[a-zA-Z0-9-]+|password\s*[:=]\s*[\"'"'"'][^\"'"'"']+[\"'"'"']|token\s*[:=]\s*[\"'"'"'][^\"'"'"']+[\"'"'"']' \
    || true)

if [ -n "$CONTENT_HITS" ]; then
    BLOCKED="$BLOCKED\n  [content match] possible secret in diff:\n$CONTENT_HITS"
fi

if [ -n "$BLOCKED" ]; then
    echo "pre-commit: BLOCKED — sensitive files or content detected:"
    printf '%s\n' "$BLOCKED"
    echo ""
    echo "Remove the files from staging (git reset HEAD <file>) or"
    echo "remove secrets from the code before committing."
    exit 1
fi

echo "pre-commit: commit safety passed"

# --- Go format and vet checks ---

STAGED_GO=$(git diff --cached --name-only --diff-filter=ACM -- '*.go' || true)
if [ -z "$STAGED_GO" ]; then
    exit 0
fi

echo "pre-commit: running go fmt..."
UNFMT=$(echo "$STAGED_GO" | xargs gofmt -l)
if [ -n "$UNFMT" ]; then
    echo "pre-commit: these files need formatting:"
    echo "$UNFMT"
    echo "Run: go fmt ./..."
    exit 1
fi

echo "pre-commit: running go vet..."
go vet ./...

echo "pre-commit: passed"
